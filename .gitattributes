# Default: normalize all text files to LF on checkout
* text=auto eol=lf

# Shell scripts must always use LF — CRLF breaks bash on Linux/macOS
*.sh text eol=lf

# Windows-specific files may use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files — never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.zip binary
*.tar binary
*.gz binary
