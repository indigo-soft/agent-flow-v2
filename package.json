{
  "name": "agent-flow-v2",
  "version": "1.0.0",
  "private": true,
  "description": "AI-Powered Development Workflow Assistant",
  "scripts": {
    "dev": "npm-run-all --parallel dev:backend dev:dashboard",
    "dev:backend": "nest start --watch",
    "dev:dashboard": "next dev src/dashboard",
    "build": "pnpm build:backend && pnpm build:dashboard",
    "build:backend": "nest build",
    "build:dashboard": "next build src/dashboard",
    "start": "node dist/main",
    "start:dashboard": "next start src/dashboard",
    "lint": "eslint \"src/**/*.{ts,tsx,js,jsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx,js,jsx}\" --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,md,prisma}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,md,prisma}\"",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@nestjs/cli": "^10.3.2",
    "@nestjs/common": "^10.2.5",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.2.5",
    "@nestjs/testing": "^10.2.5",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.1.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-security": "^2.1.0",
    "eslint-plugin-simple-import-sort": "^10.0.0",
    "eslint-plugin-unused-imports": "^3.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.2",
    "next": "^14.1.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.2.4",
    "prettier-plugin-prisma": "^5.0.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core"
    ]
  }
}
