{
  "name": "agent-flow-v2",
  "version": "0.1.1",
  "private": true,
  "description": "AI-Powered Development Workflow Assistant",
  "scripts": {
    "dev": "npm-run-all --parallel dev:backend dev:dashboard",
    "dev:backend": "nest start --watch",
    "dev:dashboard": "next dev src/components/dashboard",
    "build": "pnpm build:backend && pnpm build:dashboard",
    "build:backend": "nest build",
    "build:dashboard": "next build src/components/dashboard",
    "start": "node dist/main",
    "start:dashboard": "next start src/components/dashboard",
    "lint": "eslint \"src/**/*.{ts,tsx,js,jsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx,js,jsx}\" --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,md,prisma}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,md,prisma}\"",
    "type-check": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "prepare": "lefthook install && pnpm prepare:scripts",
    "prepare:scripts": "find scripts -name '*.sh' -exec chmod +x {} +",
    "release": "bash scripts/release/release.sh",
    "release:dry": "bash scripts/release/release.sh --dry",
    "release:patch": "bash scripts/release/release.sh --type=patch",
    "release:minor": "bash scripts/release/release.sh --type=minor",
    "release:major": "bash scripts/release/release.sh --type=major",
    "generate:agent": "node scripts/generate-agent.js",
    "generate:api": "node scripts/generate-api-endpoint.js",
    "generate:integration": "node scripts/generate-integration.js",
    "check:structure": "node scripts/check-structure.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "setup": "git config commit.template .gitmessage && lefthook install && pnpm prepare:scripts"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/compat": "^2.0.3",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/common": "^11.1.16",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.16",
    "@nestjs/testing": "^11.1.16",
    "@release-it/conventional-changelog": "^10.0.5",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "cache-manager": "^7.2.8",
    "eslint": "^10.0.3",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "lefthook": "^2.1.3",
    "lint-staged": "^16.3.3",
    "next": "16.1.7",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "prettier-plugin-prisma": "^5.0.0",
    "release-it": "^19.2.4",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "tmp@<=0.2.3": ">=0.2.4",
      "glob@>=10.2.0 <10.5.0": ">=10.5.0",
      "lodash@>=4.0.0 <=4.17.22": ">=4.17.23",
      "@isaacs/brace-expansion@<=5.0.0": ">=5.0.1",
      "minimatch@<3.1.3": ">=3.1.3",
      "minimatch@>=9.0.0 <9.0.6": ">=9.0.6",
      "minimatch@>=10.0.0 <10.2.1": ">=10.2.1",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "minimatch@>=10.0.0 <10.2.3": ">=10.2.3",
      "minimatch@<3.1.4": ">=3.1.4",
      "serialize-javascript@<=7.0.2": ">=7.0.3",
      "ajv@<6.14.0": ">=6.14.0",
      "ajv@>=7.0.0-alpha.0 <8.18.0": ">=8.18.0",
      "file-type@>=13.0.0 <21.3.1": ">=21.3.1"
    },
    "ignoredBuiltDependencies": [
      "lefthook"
    ]
  },
  "dependencies": {
    "@keyv/redis": "^5.1.6",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "keyv": "^5.6.0"
  }
}
