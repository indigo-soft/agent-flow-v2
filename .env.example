# ============================================================
# agent-flow-v2 — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# See docs/guides/deployment.md for full deployment guide.
# ============================================================
# ---- Application ----
NODE_ENV=development
PORT=3000
# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql://agentflow:your_password@localhost:5432/agentflow_db
# ---- Queue / Cache (Redis) ----
REDIS_URL=redis://localhost:6379
# ---- AI Provider ----
# API key for OpenAI / Anthropic / other provider
AI_PROVIDER_API_KEY=sk-...
# ---- GitHub Integration ----
# Personal Access Token with repo, issues, pull_requests scopes
GITHUB_TOKEN=ghp_...
# ---- Frontend (Next.js) ----
NEXT_PUBLIC_API_URL=http://localhost:3000/api
# ---- Security ----
# Random string >= 32 characters; use: openssl rand -base64 32
JWT_SECRET=your_random_jwt_secret_min_32_chars
# ---- Release (commit-and-tag-version) ----
# GitHub token used by the release script to push tags
# Same as GITHUB_TOKEN above — keep in sync
# RELEASE_GITHUB_TOKEN=ghp_...
